{% for type, messages in app.flashes %}
    {% set icon_class = {
        'success': 'bi-check-circle-fill text-white bg-success',
        'danger': 'bi-x-circle-fill text-white bg-danger',
        'warning': 'bi-exclamation-triangle-fill text-white bg-warning',
        'info': 'bi-info-circle-fill text-white bg-info'
    }[type] ?? 'bi-bell-fill text-white bg-black' %}

    <div
        class="toast align-items-center border-0 mb-3 shadow-lg rounded-4 text-white toast-{{ type }} toast-animated"
        role="alert"
        data-toast-target="toast"
        data-toast-duration-value="5000"
    >
        <div 
            class="toast align-items-center border-0 mb-3 shadow-lg rounded-3 text-white toast-{{ type }} toast-slide" 
            role="alert" 
            aria-live="assertive" 
            aria-atomic="true"
            data-toast-target="toast"
            data-toast-duration-value="5000"
            style="overflow: hidden; min-width: 320px; max-width: 400px; backdrop-filter: blur(10px);"
        >
            <div class="d-flex align-items-center">
                <!-- Icon -->
                <i class="bi {{ icon_class }} fs-4 ms-3 me-2"></i>

                <div class="toast-body flex-grow-1 position-relative">
                    {{ messages | join('. ') }}
                    
                    <!-- Progress Bar -->
                    <div class="progress mt-2 rounded-pill" style="height: 6px; background-color: rgba(255,255,255,0.2); overflow: hidden;">
                        <div class="progress-bar" role="progressbar" data-toast-target="progress" 
                             style="width: 100%; transition: width 0.05s linear;"></div>
                    </div>

                    <!-- Counter -->
                    <span data-toast-target="counter" 
                          class="position-absolute top-50 end-0 translate-middle-y me-2 fw-bold" 
                          style="font-size: 0.85rem;"></span>
                </div>

                <!-- Close button -->
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
{% endfor %}
