<div {{ attributes }}>
    <div class="mb-3">
        <label class="form-label fw-semibold">Nom de la fonction *</label>
        <input type="text" data-model="nomFon"
               class="form-control {{ _errors.has('nomFon') ? 'is-invalid' : '' }}"
               placeholder="ex: Responsable RH">
        {% if _errors.has('nomFon') %}
            <div class="invalid-feedback">{{ _errors.get('nomFon') }}</div>
        {% endif %}
    </div>
    <div class="mb-3">
        <label class="form-label">Catégorie</label>
        <select data-model="categorie" class="form-select">
            <option value="">-- Aucune --</option>
            {# Populated via repository in component #}
        </select>
    </div>
    <button class="btn btn-primary w-100"
            data-action="live#action" data-live-action-param="save">
        <i class="bi bi-check-circle me-1"></i>Enregistrer la fonction
    </button>
</div>