<div {{ attributes }}>
    <div class="mb-3">
        <label class="form-label fw-semibold">Direction *</label>
        <select data-model="direction" class="form-select">
            <option value="">-- Choisir --</option>
            {# Rendered via component ExposeInTemplate #}
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label fw-semibold">Nom du service *</label>
        <input type="text" data-model="nomSer"
               class="form-control {{ _errors.has('nomSer') ? 'is-invalid' : '' }}"
               placeholder="ex: Service RH">
        {% if _errors.has('nomSer') %}
            <div class="invalid-feedback">{{ _errors.get('nomSer') }}</div>
        {% endif %}
    </div>
    <div class="mb-3">
        <label class="form-label">Nomenclature</label>
        <input type="text" data-model="nomenSer" class="form-control" placeholder="Auto si vide">
    </div>
    <button class="btn btn-primary w-100"
            data-action="live#action" data-live-action-param="save">
        <i class="bi bi-check-circle me-1"></i>Enregistrer le service
    </button>
</div>