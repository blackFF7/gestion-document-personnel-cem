<div class="container-fluid p-2">

    {% if errorMessage %}
        <div class="alert alert-danger shadow-sm">
            {{ errorMessage }}
        </div>
    {% endif %}

    {% if success %}
        <div class="alert alert-success shadow-sm">
            ✔ Type de document ajouté avec succès
        </div>
    {% endif %}

    <div class="mb-3">
        <label class="form-label fw-bold">Nom du type de document</label>
        <input
            type="text"
            class="form-control"
            data-model="nomTypeDoc"
            placeholder="Ex: Contrat, Fiche de paie..."
        >
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Dossier</label>
        <select class="form-select" data-model="dossierId">
            <option value="">-- Choisir un dossier --</option>
            {% for dossier in this.dossiers %}
                <option value="{{ dossier.id }}">
                    {{ dossier.nomDos }}
                </option>
            {% endfor %}
        </select>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button
            class="btn btn-outline-secondary"
            data-bs-dismiss="modal"
        >
            Annuler
        </button>

        <button
            class="btn btn-primary shadow"
            data-action="live#action"
            data-live-action-param="saveTypeDocument"
        >
            💾 Enregistrer
        </button>
    </div>

</div>