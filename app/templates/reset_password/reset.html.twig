{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe | DigitDoc{% endblock %}

{% block body %}
<body class="login-page">

  <div class="bg-geo"></div>
  <div class="bg-dots"></div>
  <div class="shape shape-1" aria-hidden="true"></div>
  <div class="shape shape-2" aria-hidden="true"></div>
  <div class="shape shape-3" aria-hidden="true"></div>
  <div class="shape shape-4" aria-hidden="true"></div>

  <main class="login-wrapper">
    <div class="login-card">

      {# ── FORM SIDE ── #}
      <section class="login-form-side">

        <div class="login-logo-mobile">
          <img src="{{ asset('icons/logo3.png') }}" alt="DigitDoc" style="max-width:100px;">
        </div>

        <h1 class="form-title d-flex justify-content-center">Nouveau mot de passe</h1>
        <p class="text-center text-muted mb-4" style="font-size:.9rem;">
          Choisissez un nouveau mot de passe sécurisé.
        </p>

        {{ form_start(resetForm, {'attr': {'novalidate': 'novalidate', 'autocomplete': 'off'}}) }}

          {# ── Nouveau mot de passe ── #}
          <div class="ff-group">
            <div class="form-floating" data-controller="floating-field password">
              {{ form_widget(resetForm.plainPassword.first, {
                'attr': {
                  'class': 'form-control',
                  'placeholder': 'Nouveau mot de passe',
                  'data-floating-field-target': 'input',
                  'data-password-target': 'input'
                }
              }) }}
              <label for="{{ resetForm.plainPassword.first.vars.id }}">Nouveau mot de passe</label>

              <button type="button"
                      class="ff-btn-toggle"
                      aria-label="Afficher / masquer le mot de passe"
                      data-action="click->password#toggle">
                <span data-password-target="eyeIcon">
                  {{ ux_icon('iconamoon:eye-off-duotone')|raw }}
                </span>
                <span data-password-target="eyeSlashIcon" class="d-none">
                  {{ ux_icon('mdi:eye-outline')|raw }}
                </span>
              </button>
            </div>
            {% if form_errors(resetForm.plainPassword.first) %}
              <div class="alert-dd mt-1" role="alert">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>{{ form_errors(resetForm.plainPassword.first) }}</span>
              </div>
            {% endif %}
          </div>

          {# ── Confirmation mot de passe ── #}
          <div class="ff-group">
            <div class="form-floating" data-controller="floating-field password">
              {{ form_widget(resetForm.plainPassword.second, {
                'attr': {
                  'class': 'form-control',
                  'placeholder': 'Confirmer le mot de passe',
                  'data-floating-field-target': 'input',
                  'data-password-target': 'input'
                }
              }) }}
              <label for="{{ resetForm.plainPassword.second.vars.id }}">Confirmer le mot de passe</label>

              <button type="button"
                      class="ff-btn-toggle"
                      aria-label="Afficher / masquer le mot de passe"
                      data-action="click->password#toggle">
                <span data-password-target="eyeIcon">
                  {{ ux_icon('iconamoon:eye-off-duotone')|raw }}
                </span>
                <span data-password-target="eyeSlashIcon" class="d-none">
                  {{ ux_icon('mdi:eye-outline')|raw }}
                </span>
              </button>
            </div>
            {% if form_errors(resetForm.plainPassword.second) %}
              <div class="alert-dd mt-1" role="alert">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>{{ form_errors(resetForm.plainPassword.second) }}</span>
              </div>
            {% endif %}
          </div>

          {# ── Erreurs globales du formulaire ── #}
          {% if form_errors(resetForm) %}
            <div class="alert-dd mb-3" role="alert">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <span>{{ form_errors(resetForm) }}</span>
            </div>
          {% endif %}

          <button class="btn-submit" type="submit">
            {{ ux_icon('mdi:lock-reset') }} Réinitialiser le mot de passe
          </button>

          <div class="text-center mt-3">
            <a href="{{ path('app_login') }}" style="font-size:.85rem; color:var(--dd-primary);">
              {{ ux_icon('mdi:arrow-left') }} Retour à la connexion
            </a>
          </div>

        {{ form_end(resetForm) }}

      </section>

      {# ── BRAND SIDE ── #}
      <aside class="login-brand-side" aria-hidden="true">
        <div class="brand-accent"></div>
        <div class="brand-ring"></div>
        <div class="brand-ring"></div>
        <div class="brand-ring"></div>
        <div class="brand-logo-wrap">
          <img src="{{ asset('icons/logo3.png') }}" alt="DigitDoc">
        </div>
        <h2 class="brand-title">
          <span class="text-light">Digit</span><span class="text-warning">Doc</span>
        </h2>
        <div class="brand-divider"></div>
        <p class="brand-tagline">Le partenaire de votre document</p>
      </aside>

    </div>
  </main>

</body>
{% endblock %}