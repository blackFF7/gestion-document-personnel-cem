{# ════════════════════════════════════════════════════════
   PAGE HEADER
   ════════════════════════════════════════════════════════ #}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-3">
        <div style="width:40px;height:40px;border-radius:.6rem;background:var(--pf-accent-lt);display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-person-lines-fill" style="color:var(--pf-accent);font-size:1.1rem;"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-bold" style="font-size:1.1rem;color:var(--pf-text);">{{ btn_label }}</h4>
            <p class="mb-0 small" style="color:var(--pf-muted);">Fiche personnel — Gestion des ressources humaines</p>
        </div>
    </div>
    <div class="d-none d-md-flex gap-2 pf-desktop-actions">
        <a href="{{ path('app_agent_index') }}" class="pf-btn pf-btn-ghost">
            <i class="bi bi-x-lg"></i> Annuler
        </a>
        <button type="submit" form="personnelForm" class="pf-btn pf-btn-primary">
            <i class="bi bi-save"></i> {{ btn_label }}
        </button>
    </div>
</div>

{{ form_start(form, {attr: {novalidate: 'novalidate', id: 'personnelForm'}}) }}

<div class="row g-3">

    {# ══════════════════════════════════
       COLONNE SIDEBAR
       ══════════════════════════════════ #}
    <div class="col-lg-3 order-lg-1 order-2">
        <div class="pf-card pf-sidebar-sticky">
            <div class="pf-card-body text-center pt-4 pb-3">

                {# Avatar preview #}
                <div class="pf-avatar-wrap mb-3">
                    {% if personnel.photoProfil and photoUrl %}
                        <img src="{{ photoUrl }}" class="pf-avatar-img" id="previewImg" alt="Photo">
                    {% else %}
                        <div class="pf-avatar-initials" id="previewInitials">
                            {{ (personnel.nomAg ?? 'N')|first|upper }}{{ (personnel.prenomAg ?? 'P')|first|upper }}
                        </div>
                    {% endif %}
                    <div class="pf-avatar-badge"><i class="bi bi-pencil-fill"></i></div>
                </div>

                {% if not is_new %}
                <div class="mb-3">
                    {% set sc = personnel.statusCompte?.value %}
                    <span class="pf-badge pf-badge-{{ sc|lower|replace({' ':'-','é':'e','î':'i'}) }}">
                        <i class="bi bi-circle-fill" style="font-size:.45rem;"></i>
                        {{ sc }}
                    </span>
                </div>
                {% endif %}

                <hr class="pf-divider">

                {# Nav steps #}
                <ul class="pf-nav text-start">
                    <li class="active" onclick="scrollToSection('sec-photo')">
                        <span class="pf-nav-dot"></span> Photo de profil
                    </li>
                    {% if form.nomAg is defined %}
                    <li onclick="scrollToSection('sec-identite')">
                        <span class="pf-nav-dot"></span> Identité
                    </li>
                    <li onclick="scrollToSection('sec-compte')">
                        <span class="pf-nav-dot"></span> Compte &amp; Rôle
                    </li>
                    <li onclick="scrollToSection('sec-fonction')">
                        <span class="pf-nav-dot"></span> Fonction
                    </li>
                    <li onclick="scrollToSection('sec-affectation')">
                        <span class="pf-nav-dot"></span> Affectation
                    </li>
                    {% endif %}
                    <li onclick="scrollToSection('sec-coordonnees')">
                        <span class="pf-nav-dot"></span> Coordonnées
                    </li>
                    <li onclick="scrollToSection('sec-famille')">
                        <span class="pf-nav-dot"></span> Situation familiale
                    </li>
                    <li onclick="scrollToSection('sec-password')">
                        <span class="pf-nav-dot"></span> Mot de passe
                    </li>
                </ul>
            </div>
        </div>
    </div>

    {# ══════════════════════════════════
       COLONNE PRINCIPALE
       ══════════════════════════════════ #}
    <div class="col-lg-9 order-lg-2 order-1">

        {# ── § Photo de profil ── #}
        <div id="sec-photo" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-image"></i></div>
                    <span class="pf-card-title">Photo de profil</span>
                </div>
            </div>
            <div class="pf-card-body">
                <div class="pf-file-wrap" id="photoDropzone">
                    {{ form_widget(form.photoProfilFile, {attr: {id: 'photoFileInput', class: ''}}) }}
                    <div class="pf-file-ico"><i class="bi bi-person-circle"></i></div>
                    <div class="pf-file-label">
                        <strong>Cliquez</strong> ou glissez une image<br>
                        <span style="font-size:.7rem;color:#94a3b8;">JPG, PNG, WEBP, GIF — max 5 Mo</span>
                    </div>
                    {% if personnel.photoProfil %}
                    <div style="margin-top:.5rem;font-size:.75rem;color:var(--pf-success);">
                        <i class="bi bi-check-circle me-1"></i>Photo actuelle chargée
                    </div>
                    {% endif %}
                </div>
                {{ form_errors(form.photoProfilFile) }}
            </div>
        </div>

        {% if form.nomAg is defined %}

        {# ── § Identité ── #}
        <div id="sec-identite" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-person-badge"></i></div>
                    <span class="pf-card-title">Identité</span>
                </div>
            </div>
            <div class="pf-card-body">
                <div class="row g-3">
                    <div class="col-5 col-sm-3 col-lg-2">
                        <label class="pf-label">IM <span class="req">*</span></label>
                        {{ form_widget(form.IM, {attr: {class: 'pf-input', placeholder: '001'}}) }}
                        {{ form_errors(form.IM) }}
                    </div>
                    <div class="col-7 col-sm-4 col-lg-5">
                        <label class="pf-label">Nom <span class="req">*</span></label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-person pf-ico"></i>
                            {{ form_widget(form.nomAg, {attr: {class: 'pf-input', placeholder: 'Nom de famille', id: 'nomInput'}}) }}
                        </div>
                        {{ form_errors(form.nomAg) }}
                    </div>
                    <div class="col-12 col-sm-5 col-lg-5">
                        <label class="pf-label">Prénom <span class="req">*</span></label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-person pf-ico"></i>
                            {{ form_widget(form.prenomAg, {attr: {class: 'pf-input', placeholder: 'Prénom(s)', id: 'prenomInput'}}) }}
                        </div>
                        {{ form_errors(form.prenomAg) }}
                    </div>
                    <div class="col-12 col-sm-4">
                        <label class="pf-label">Date de naissance</label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-calendar3 pf-ico"></i>
                            {{ form_widget(form.dateNaissAg, {attr: {class: 'pf-input'}}) }}
                        </div>
                        {{ form_errors(form.dateNaissAg) }}
                    </div>
                    <div class="col-12 col-sm-4">
                        <label class="pf-label">Date d'entrée</label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-calendar-check pf-ico"></i>
                            {{ form_widget(form.dateEntre, {attr: {class: 'pf-input'}}) }}
                        </div>
                        {{ form_errors(form.dateEntre) }}
                    </div>
                    <div class="col-12 col-sm-4">
                        <label class="pf-label">Sexe</label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-gender-ambiguous pf-ico"></i>
                            {{ form_widget(form.sexe, {attr: {class: 'pf-select'}}) }}
                        </div>
                        {{ form_errors(form.sexe) }}
                    </div>
                </div>
            </div>
        </div>

        {# ── § Compte & Rôle ── #}
        <div id="sec-compte" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-shield-lock"></i></div>
                    <span class="pf-card-title">Compte &amp; Rôle</span>
                </div>
            </div>
            <div class="pf-card-body">
                <div class="row g-3">
                    <div class="col-12 col-sm-8">
                        <div class="pf-switch-wrap mb-2">
                            <label class="pf-switch">
                                {{ form_widget(form.autoUsername, {attr: {id: 'autoUsernameSwitch'}}) }}
                                <span class="pf-switch-slider"></span>
                            </label>
                            <span style="font-size:.82rem;font-weight:600;color:var(--pf-text);">
                                Générer le nom d'utilisateur automatiquement
                            </span>
                        </div>
                        <div id="usernameFieldWrap">
                            <label class="pf-label">Nom d'utilisateur</label>
                            <div class="pf-icon-wrap">
                                <i class="bi bi-at pf-ico"></i>
                                {{ form_widget(form.username, {attr: {class: 'pf-input', placeholder: 'nom.prenom'}}) }}
                            </div>
                            {{ form_errors(form.username) }}
                        </div>
                    </div>
                    {% if form.roles is defined %}
                    <div class="col-12">
                        <label class="pf-label">Rôle attribué <span class="req">*</span></label>
                        <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.35rem;">
                            {% for choice in form.roles %}
                            <label class="pf-role-label"
                                   style="display:flex;align-items:center;gap:.4rem;font-size:.82rem;
                                          padding:.35rem .75rem;border-radius:.4rem;cursor:pointer;
                                          border:1.5px solid var(--pf-border);background:#fafbfc;transition:all .15s;">
                                {{ form_widget(choice, {attr: {class: 'pf-role-check', style: 'width:14px;height:14px;accent-color:var(--pf-accent);'}}) }}
                                {{ choice.vars.label }}
                            </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.roles) }}
                    </div>
                    {% endif %}
                    {% if form.statusCompte is defined %}
                    <div class="col-12 col-sm-4">
                        <label class="pf-label">Statut du compte</label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-toggle-on pf-ico"></i>
                            {{ form_widget(form.statusCompte, {attr: {class: 'pf-select'}}) }}
                        </div>
                        {{ form_errors(form.statusCompte) }}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ── § Fonction ── #}
        <div id="sec-fonction" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-briefcase"></i></div>
                    <span class="pf-card-title">Fonction</span>
                </div>
                <button type="button" class="pf-btn pf-btn-outline pf-btn-sm"
                        data-bs-toggle="modal" data-bs-target="#modalFonction">
                    <i class="bi bi-plus-lg"></i> Nouvelle fonction
                </button>
            </div>
            <div class="pf-card-body">
                <div class="row g-3">
                    <div class="col-12 col-sm-9">
                        {#
                            AutocompleteField — Tom Select est injecté automatiquement.
                            Pas besoin de class="pf-select", Tom Select crée son propre wrapper.
                            On peut styliser via .ts-wrapper dans le CSS.
                        #}
                        {{ form_row(form.fonctionID) }}
                    </div>
                </div>
            </div>
        </div>

        {# ── § Affectation (Agence ou Service) ── #}
        <div id="sec-affectation" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-building"></i></div>
                    <span class="pf-card-title">Affectation</span>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="pf-btn pf-btn-outline pf-btn-sm"
                            data-bs-toggle="modal" data-bs-target="#modalAgence">
                        <i class="bi bi-plus-lg"></i> Agence
                    </button>
                    <button type="button" class="pf-btn pf-btn-outline pf-btn-sm"
                            data-bs-toggle="modal" data-bs-target="#modalService">
                        <i class="bi bi-plus-lg"></i> Service
                    </button>
                </div>
            </div>
            <div class="pf-card-body">

                {# Radio cards Agence / Service #}
                <div class="mb-3">
                    <label class="pf-label">Type d'affectation <span class="req">*</span></label>
                    <div class="pf-affectation-cards">
                        <label class="pf-aff-card" id="affAgenceCard">
                            <input type="radio" name="_affectation_type" value="agence"
                                   id="affTypeAgence" onchange="switchAffectation('agence')">
                            <div class="pf-aff-card-ico"><i class="bi bi-building"></i></div>
                            <div class="pf-aff-card-label">Agence</div>
                        </label>
                        <label class="pf-aff-card" id="affServiceCard">
                            <input type="radio" name="_affectation_type" value="service"
                                   id="affTypeService" onchange="switchAffectation('service')">
                            <div class="pf-aff-card-ico"><i class="bi bi-building-gear"></i></div>
                            <div class="pf-aff-card-label">Service / Direction</div>
                        </label>
                    </div>
                    {# Champ caché BackFront mappé sur l'entité #}
                    {{ form_widget(form.BackFront, {attr: {id: 'backFrontHidden', style: 'display:none'}}) }}
                </div>

                {# Panel Agence — AutocompleteField #}
                <div id="panelAgence" class="pf-aff-select-panel" style="display:none;">
                    {{ form_row(form.agenceField) }}
                </div>

                {# Panel Service — AutocompleteField + direction auto #}
                <div id="panelService" class="pf-aff-select-panel" style="display:none;">
                    <div class="row g-3">
                        <div class="col-12">
                            {#
                                On surcharge le label via form_label pour garder le style cohérent.
                                form_widget suffit : Tom Select génère son propre DOM.
                            #}
                            {{ form_row(form.serviceField) }}
                        </div>
                        <div class="col-12">
                            <label class="pf-label">Direction liée</label>
                            <input type="text" id="directionDisplay" class="pf-input"
                                   readonly placeholder="Direction automatique">
                        </div>
                    </div>
                </div>

            </div>
        </div>

        {% endif %}{# end if form.nomAg #}

        {# ── § Coordonnées ── #}
        <div id="sec-coordonnees" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-envelope"></i></div>
                    <span class="pf-card-title">Coordonnées</span>
                </div>
            </div>
            <div class="pf-card-body">
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label class="pf-label">Adresse e-mail</label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-envelope pf-ico"></i>
                            {{ form_widget(form.mailAg, {attr: {class: 'pf-input', placeholder: 'email@domaine.com'}}) }}
                        </div>
                        {{ form_errors(form.mailAg) }}
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="pf-label">Adresse postale</label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-geo-alt pf-ico" style="top:.85rem;transform:none;"></i>
                            {{ form_widget(form.adresseAg, {attr: {class: 'pf-textarea', rows: 2, placeholder: 'Rue, quartier, ville…', style: 'padding-left:2.2rem;'}}) }}
                        </div>
                        {{ form_errors(form.adresseAg) }}
                    </div>

                    {# ── Téléphones multiples ── #}
                    <div class="col-12">
                        <label class="pf-label">Numéros de téléphone</label>
                        <div class="pf-phone-list" id="phoneList"></div>
                        {{ form_widget(form.contactAg, {attr: {id: 'contactAgHidden', style: 'display:none'}}) }}
                        <div style="margin-top:.5rem;">
                            <button type="button" class="pf-add-btn" onclick="addPhone()">
                                <i class="bi bi-plus-lg"></i> Ajouter un numéro
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# ── § Situation familiale ── #}
        <div id="sec-famille" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-heart"></i></div>
                    <span class="pf-card-title">Situation familiale</span>
                </div>
            </div>
            <div class="pf-card-body">
                <div class="row g-3 mb-3">
                    <div class="col-12 col-sm-5">
                        <label class="pf-label">Situation <span class="req">*</span></label>
                        <div class="pf-icon-wrap">
                            <i class="bi bi-people pf-ico"></i>
                            {{ form_widget(form.situationFamilial, {attr: {class: 'pf-select', id: 'situationSelect', onchange: 'toggleConjoint(this.value)'}}) }}
                        </div>
                        {{ form_errors(form.situationFamilial) }}
                    </div>
                </div>

                {# Conjoint #}
                <div id="conjointSection" style="display:none;">
                    <hr class="pf-divider">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-person-heart" style="color:var(--pf-accent);"></i>
                        <span style="font-size:.82rem;font-weight:600;color:var(--pf-text);">Conjoint(e)</span>
                    </div>
                    <div class="pf-famille-card">
                        <div class="row g-3">
                            {% if form.conjoint is defined and form.conjoint.nom is defined %}
                                <div class="col-12 col-sm-4">
                                    <label class="pf-label">Nom</label>
                                    {{ form_widget(form.conjoint.nom, {attr: {class: 'pf-input', placeholder: 'Nom du conjoint'}}) }}
                                    {{ form_errors(form.conjoint.nom) }}
                                </div>
                                <div class="col-12 col-sm-4">
                                    <label class="pf-label">Prénom</label>
                                    {{ form_widget(form.conjoint.prenom, {attr: {class: 'pf-input', placeholder: 'Prénom'}}) }}
                                    {{ form_errors(form.conjoint.prenom) }}
                                </div>
                                <div class="col-12 col-sm-4">
                                    <label class="pf-label">Date de naissance</label>
                                    {{ form_widget(form.conjoint.dateNaiss, {attr: {class: 'pf-input'}}) }}
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label class="pf-label">Profession</label>
                                    {{ form_widget(form.conjoint.profession, {attr: {class: 'pf-input', placeholder: 'Profession'}}) }}
                                </div>
                            {% else %}
                                <div class="col-12">
                                    <div class="pf-alert pf-alert-info">
                                        <i class="bi bi-info-circle-fill"></i>
                                        Les informations du conjoint sont gérées depuis la fiche de profil après enregistrement.
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {# Enfants #}
                <div id="enfantsSection" style="margin-top:.75rem;">
                    <hr class="pf-divider">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-people-fill" style="color:var(--pf-accent);"></i>
                            <span style="font-size:.82rem;font-weight:600;color:var(--pf-text);">
                                Enfants <span id="enfantCount" style="font-size:.75rem;font-weight:400;color:var(--pf-muted);">(0)</span>
                            </span>
                        </div>
                        <button type="button" class="pf-add-btn" onclick="addEnfant()">
                            <i class="bi bi-plus-lg"></i> Ajouter un enfant
                        </button>
                    </div>
                    <div class="pf-famille-grid" id="enfantsList">
                        {% if form.enfants is defined %}
                            {% for enfantForm in form.enfants %}
                            <div class="pf-famille-card" data-enfant>
                                <div class="pf-famille-card-head">
                                    <span class="pf-famille-card-title"><i class="bi bi-person-fill me-1"></i>Enfant</span>
                                    <button type="button" class="pf-remove-card" onclick="removeCard(this)">
                                        {{ ux_icon('mdi:trash') }}
                                    </button>
                                </div>
                                <div class="row g-2">
                                    <div class="col-12 col-sm-3">
                                        <label class="pf-label">Nom</label>
                                        {{ form_widget(enfantForm.nom, {attr: {class: 'pf-input', placeholder: 'Nom'}}) }}
                                    </div>
                                    <div class="col-12 col-sm-3">
                                        <label class="pf-label">Prénom</label>
                                        {{ form_widget(enfantForm.prenom, {attr: {class: 'pf-input', placeholder: 'Prénom'}}) }}
                                    </div>
                                    <div class="col-7 col-sm-3">
                                        <label class="pf-label">Date naiss.</label>
                                        {{ form_widget(enfantForm.dateNaiss, {attr: {class: 'pf-input'}}) }}
                                    </div>
                                    <div class="col-5 col-sm-3">
                                        <label class="pf-label">Sexe</label>
                                        {{ form_widget(enfantForm.sexe, {attr: {class: 'pf-select'}}) }}
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>

        {# ── § Mot de passe ── #}
        <div id="sec-password" class="pf-card pf-section">
            <div class="pf-card-head">
                <div class="pf-card-head-left">
                    <div class="pf-card-icon"><i class="bi bi-lock"></i></div>
                    <span class="pf-card-title">Mot de passe</span>
                </div>
            </div>
            <div class="pf-card-body">
                <div class="pf-alert pf-alert-warn mb-3">
                    <i class="bi bi-shield-exclamation"></i>
                    {% if not is_new %}
                        Laissez vide pour conserver le mot de passe actuel.
                    {% else %}
                        Si vide, le nom de famille sera utilisé comme mot de passe par défaut.
                    {% endif %}
                </div>
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label class="pf-label">Nouveau mot de passe</label>
                        <div class="pf-igroup">
                            {{ form_widget(form.plainPassword.first, {attr: {class: 'pf-input', placeholder: '••••••••', id: 'pwd1'}}) }}
                            <button type="button" class="pf-igroup-btn" onclick="togglePwd('pwd1',this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.first) }}
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="pf-label">Confirmer le mot de passe</label>
                        <div class="pf-igroup">
                            {{ form_widget(form.plainPassword.second, {attr: {class: 'pf-input', placeholder: '••••••••', id: 'pwd2'}}) }}
                            <button type="button" class="pf-igroup-btn" onclick="togglePwd('pwd2',this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.second) }}
                    </div>
                </div>
            </div>
        </div>

    </div>{# /col-lg-9 #}
</div>{# /row #}

{{ form_end(form) }}

{# Barre mobile #}
<div class="pf-mobile-bar">
    <a href="{{ path('app_agent_index') }}" class="pf-btn pf-btn-ghost">
        <i class="bi bi-x-lg"></i> Annuler
    </a>
    <button type="submit" form="personnelForm" class="pf-btn pf-btn-primary">
        <i class="bi bi-save"></i> {{ btn_label }}
    </button>
</div>
<div class="pf-mobile-spacer d-lg-none"></div>


