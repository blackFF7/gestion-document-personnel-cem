{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-4">
  <h1>Tableau de bord</h1>

  <div class="row">
    <div class="col-12">
      <div class="list-group mt-3">
        {% for doc in documents %}
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <div class="fw-bold">{{ doc.titre ?: doc.reference }}</div>
              <small class="text-muted">
                Titulaire: {{ doc.personnelID.fullName }} · 
                Dossier: {{ doc.typeDocument.dossier.nomDos }} · 
                Niveau: {{ doc.typeDocument.dossier.niveauConf }} · 
                Statut: {{ doc.statucDoc.value }}
              </small>
            </div>

            <div class="btn-group">
              {% if is_granted('VIEW', doc) %}
                <a href="" class="btn btn-sm btn-outline-primary">Voir</a>
              {% endif %}
              {% if is_granted('EDIT', doc) %}
                <a href="{{ path('document_edit', {id: doc.id}) }}" class="btn btn-sm btn-outline-secondary">Éditer</a>
              {% endif %}
              {% if is_granted('DELETE', doc) %}
                <a href="{{ path('document_delete', {id: doc.id}) }}" class="btn btn-sm btn-outline-danger">Supprimer</a>
              {% endif %}
            </div>
          </div>
        {% else %}
          <div class="alert alert-info">Aucun document disponible.</div>
        {% endfor %}
      </div>

      {# Pagination en dehors de la boucle #}
      {% if documents|length %}
        <div class="navigation d-flex justify-content-center mt-4">
          {{ knp_pagination_render(documents) }}
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}