APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
APP_DEBUG=1
TRUSTED_HOSTS='^(localhost|127\.0\.0\.1|192\.168\.1\.\d+)$'

DEFAULT_URI=http://localhost:8001
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://digituser:blackdev007@postgres:5432/digitdb?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> Redis ###
REDIS_PASSWORD=blackdev007
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
###< Redis ###

###> MinIO ###
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=blackdev007
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=blackdev007
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_PREVIEWS=previews
MINIO_BUCKET_PHOTOS=photos-profil
MINIO_REGION=us-east-1
MINIO_USE_PATH_STYLE=true
###< MinIO ###

###> upload ###
UPLOAD_DIR=%kernel.project_dir%/public/uploads
###< upload ###

###> knplabs/knp-snappy-bundle ###
WKHTMLTOPDF_PATH=/usr/local/bin/wkhtmltopdf
WKHTMLTOIMAGE_PATH=/usr/local/bin/wkhtmltoimage
###< knplabs/knp-snappy-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|192\.168\.1\.\d+)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailhog:1025
# ou pour prod :
# MAILER_DSN=smtp://user:pass@smtp.example.com:587
###< symfony/mailer ###

###> symfony/mercure-notifier ###
# MERCURE_DSN=mercure://default
###< symfony/mercure-notifier ###

###> symfony/mercure-bundle ###
# See https://symfony.com/doc/current/mercure.html#configuration
# The URL of the Mercure hub, used by the app to publish updates (can be a local URL)
MERCURE_URL=http://localhost:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
MERCURE_JWT_SECRET="blackdev007"
###< symfony/mercure-bundle ###
